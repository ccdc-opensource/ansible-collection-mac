<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ccdc.mac_optimisation.sysctl</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>/usr/sbin/sysctl -w net.inet.tcp.delayed_ack=0; /usr/sbin/sysctl -w net.inet.tcp.tso=0</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
